# Base URL of the Recruit Wizard API.
# Production: https://recruitwizard.app
# Sandbox:    https://sandbox.recruitwizard.site
HOST=https://sandbox.recruitwizard.site

# OAuth client credentials issued when you registered your application.
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Redirect URI registered with your Recruit Wizard application.
# This MUST exactly match one of the URLs you registered.
REDIRECT_URI=http://localhost:3000/auth/callback

# Local server port (optional, defaults to 3000).
# PORT=3000
