# ASP.NET Core reads environment variables natively. Names use double-underscore
# (`__`) to map onto config sections — e.g. `RecruitWizard__ClientId` overrides
# `RecruitWizard:ClientId` from appsettings.json.
#
# You can either:
#   1. Set these in your shell before `dotnet run`, or
#   2. Edit `appsettings.json` (or use `dotnet user-secrets`) instead.

# Base URL of the Recruit Wizard API.
# Production: https://recruitwizard.app
# Sandbox:    https://sandbox.recruitwizard.site
RecruitWizard__Host=https://sandbox.recruitwizard.site

# OAuth client credentials issued when you registered your application.
RecruitWizard__ClientId=your-client-id-here
RecruitWizard__ClientSecret=your-client-secret-here

# Redirect URI registered with your Recruit Wizard application.
# This MUST exactly match a URL that Recruit Wizard support has white-listed
# on your client.
#
# For testing, prefer a https://webhook.site/<uuid> URL — it works without
# exposing localhost via ngrok / a tunnel. The flow is:
#   1. Visit https://webhook.site to grab a unique URL.
#   2. Send that URL to Recruit Wizard support to be white-listed.
#   3. Set it below, run the app, sign in, and copy the `code` query
#      parameter from the request webhook.site captures.
RecruitWizard__RedirectUri=https://webhook.site/your-unique-id-here

# Local server URL the sample listens on (optional, default http://localhost:3000).
# ASPNETCORE_URLS=http://localhost:3000
